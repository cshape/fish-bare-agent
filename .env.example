# STT — Deepgram Flux (turn-taking + transcription in one websocket)
DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=flux-general-en
# DEEPGRAM_EOT_THRESHOLD=0.7    # 0.5–0.9; lower = snappier end-of-turn
# DEEPGRAM_EOT_TIMEOUT_MS=3000  # max silence before forcing end-of-turn
# DEEPGRAM_EAGER_EOT_THRESHOLD=0.5  # confidence for speculative generation (EagerEndOfTurn)

# LLM — any OpenAI-compatible /chat/completions endpoint
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=google/gemma-4-26B-A4B-it

# TTS — Fish Audio
FISH_API_KEY=
FISH_MODEL=s2.1-pro
FISH_VOICE=            # reference voice id (optional)
# FISH_LATENCY_MODE=balanced  # normal | balanced | low

PORT=8787
# GATEWAY_URL=http://127.0.0.1:8788  # WebRTC media gateway (see gateway/)
# TURN relay handed to WebRTC clients — required for cellular/CGNAT devices.
# TURN_URLS=turn:host:443,turn:host:443?transport=tcp
# TURN_USERNAME=
# TURN_PASSWORD=
# SYSTEM_PROMPT=You are ...
# VAD_THRESHOLD_DB=-40  # energy gate (dBFS) used only to measure turn-detect latency
